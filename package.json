{
  "name": "totalcover",
  "version": "1.0.0",
  "description": "AI-driven test coverage boost platform for pingcap/tidb",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
