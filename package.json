    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openai/codex-sdk": "latest",
    "glob": "^11.0.3",
    "p-limit": "^7.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@9.5.0"
}
